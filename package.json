{
  "name": "cc-dice",
  "version": "0.3.0",
  "description": "Generic probabilistic dice trigger system for Claude Code hooks",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "cc-dice": "./bin/cc-dice.ts"
  },
  "files": [
    "src",
    "bin",
    "hooks",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "./tests/bats/bin/bats tests/unit/test_cc_dice.bats",
    "install-hooks": "./install.sh"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pro-vi/cc-dice.git"
  },
  "homepage": "https://github.com/pro-vi/cc-dice#readme",
  "bugs": {
    "url": "https://github.com/pro-vi/cc-dice/issues"
  },
  "author": "provi",
  "license": "MIT",
  "keywords": ["claude-code", "pi-extension", "dice", "hooks"],
  "pi": {
    "extensions": ["./src/adapters/pi/index.ts"]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.0",
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "bun-types": "^1.3.9"
  }
}
