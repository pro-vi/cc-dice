{
  "name": "agent-dice",
  "version": "0.5.0",
  "description": "Probabilistic dice triggers for AI agent hooks — host-agnostic core with Claude Code and Pi adapters",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "agent-dice": "bin/agent-dice.ts",
    "cc-dice": "bin/agent-dice.ts"
  },
  "files": [
    "src",
    "bin",
    "hooks",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "./tests/bats/bin/bats tests/unit/test_cc_dice.bats",
    "install-hooks": "./install.sh"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-vi/agent-dice.git"
  },
  "homepage": "https://github.com/pro-vi/agent-dice#readme",
  "bugs": {
    "url": "https://github.com/pro-vi/agent-dice/issues"
  },
  "author": "provi",
  "license": "MIT",
  "keywords": [
    "agent",
    "claude-code",
    "pi",
    "pi-extension",
    "dice",
    "hooks"
  ],
  "pi": {
    "extensions": [
      "./src/adapters/pi/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.0",
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "bun-types": "^1.3.9",
    "typebox": "^1.1.38"
  }
}
